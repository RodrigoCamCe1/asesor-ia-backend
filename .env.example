NODE_ENV=development
HOST=0.0.0.0
PORT=4000

DATABASE_URL=postgres://postgres:postgres@postgres:5432/easysales

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

MAGIC_LINK_TTL_MINUTES=15
MAGIC_LINK_BASE_URL=http://localhost:5173/auth/callback

CORS_ORIGIN=http://localhost:5173,http://localhost:3000

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EasySales IA <no-reply@easysales.local>

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Backend public URL (for OAuth redirects)
BACKEND_PUBLIC_URL=http://localhost:4000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Qdrant Cloud (vector DB for RAG)
QDRANT_URL=https://tu-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=tu-api-key-de-qdrant-cloud
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
